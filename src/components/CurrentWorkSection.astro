---
import { currentProjects } from '../data/currentProjects.js';
---

<div class="container project-page-container">
  <h1 class="page-title">Current Work</h1>

  <!-- Project Summaries Section -->
  <section class="project-summaries">
    {currentProjects.map((project) => (
      <div class="project-summary-item">
        <div class="project-summary-image">
          <img src={project.image} alt={`${project.title} Project`} />
        </div>
        <div class="project-summary-content">
          <a href={`/projects/${project.slug}`} class="project-summary-link">
            <h3 class="project-summary-title">{project.title}</h3>
          </a>
          <p class="project-summary-description">{project.description}</p>
        </div>
      </div>
    ))}
  </section>
</div>
